{
  "name": "@johnymontana/openclaw-neo4j-memory",
  "version": "0.2.0",
  "description": "Graph-native long-term memory for OpenClaw using Neo4j",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "openclaw",
    "neo4j",
    "memory",
    "graph",
    "agent",
    "plugin"
  ],
  "author": "johnymontana",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnymontana/openclaw-neo4j-agent-memory-plugin.git"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "npmSpec": "@johnymontana/openclaw-neo4j-memory",
      "defaultChoice": "npm"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "vitest run --project e2e",
    "pack:smoke": "npm pack --dry-run"
  },
  "files": [
    "dist/",
    "src/",
    "openclaw.plugin.json",
    "server/",
    "skills/",
    "tools/",
    "README.md"
  ],
  "dependencies": {
    "@johnymontana/neo4j-local": "latest"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
