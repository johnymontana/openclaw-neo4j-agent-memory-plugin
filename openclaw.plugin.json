{
  "name": "neo4j-memory",
  "version": "0.2.0",
  "description": "Graph-native long-term memory for OpenClaw using Neo4j (auto-managed local instance)",
  "skills": ["skills/"],
  "config": [
    {
      "key": "memory.neo4j.port",
      "required": false,
      "default": "7575",
      "description": "Bridge server port"
    },
    {
      "key": "memory.neo4j.agent_id",
      "required": false,
      "default": "default",
      "description": "Agent identity for memory namespace scoping"
    },
    {
      "key": "memory.neo4j.instance",
      "required": false,
      "default": "openclaw-memory",
      "description": "Neo4j local instance name"
    },
    {
      "key": "memory.neo4j.observational",
      "required": false,
      "default": "false",
      "description": "Enable observational memory (Phase 2 feature)"
    }
  ],
  "lifecycle": {
    "start": "server/start.sh",
    "stop": "server/stop.sh"
  }
}
