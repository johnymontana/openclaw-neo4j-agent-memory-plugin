{
  "id": "openclaw-neo4j-memory",
  "name": "Neo4j Memory",
  "version": "0.1.2",
  "description": "Graph-native long-term memory for OpenClaw using Neo4j (auto-managed local instance)",
  "kind": "memory",
  "skills": ["skills/"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "bridgePort": {
        "type": "integer",
        "minimum": 1,
        "maximum": 65535,
        "default": 7575
      },
      "agentId": {
        "type": "string",
        "default": "default"
      },
      "instance": {
        "type": "string",
        "default": "openclaw-memory"
      },
      "observational": {
        "type": "boolean",
        "default": false
      }
    }
  },
  "uiHints": {
    "bridgePort": {
      "label": "Bridge Port"
    },
    "agentId": {
      "label": "Agent ID"
    },
    "instance": {
      "label": "Neo4j Instance"
    },
    "observational": {
      "label": "Enable Observational Memory"
    }
  }
}
